+    // TAI64N format: 8 bytes seconds + 4 bytes nanoseconds.
+    //
+    // This timestamp is WireGuard's anti-replay token ("Silence is a Virtue",
+    // wireguard.c): the RESPONDER records the greatest timestamp it has seen from each
+    // peer and SILENTLY DROPS any handshake initiation whose timestamp is <= that one.
+    // It therefore MUST be wall-clock time, not uptime. The previous implementation used
+    // esp_timer_get_time() (microseconds since boot), so our handshake timestamp reset to
+    // ~0 on every reboot; after the first session the responder kept the larger timestamp
+    // from the prior boot and rejected all our re-handshakes as replays (initiations got
+    // no response) until its peer state happened to be torn down -> intermittent
+    // "connects once, then dead after reboot" failures. The device syncs real time over
+    // SNTP (hal_network.cpp), so gettimeofday() is correct and, crucially, monotonic
+    // across reboots.
+    struct timeval tv;
+    gettimeofday(&tv, NULL);
+    uint64_t seconds = (uint64_t)tv.tv_sec;
+    uint32_t nanoseconds = (uint32_t)tv.tv_usec * 1000u;
 
-    // Log raw uptime before TAI offset (only every ~5s to avoid spam)
+    // Log every ~5s to confirm real epoch time (not uptime) is in use.
     static uint64_t last_log_s = 0;
     if (seconds - last_log_s >= 5) {
-        printf("[TAI64N] uptime=%llu s, nano=%lu\n", (unsigned long long)seconds, (unsigned long)nanoseconds);
+        printf("[TAI64N] epoch=%llu s, nano=%lu\n", (unsigned long long)seconds, (unsigned long)nanoseconds);
         last_log_s = seconds;
     }
 
