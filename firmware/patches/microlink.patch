diff --git a/components/microlink/src/ml_derp.c b/components/microlink/src/ml_derp.c
index c57fd0f..6748df6 100644
--- a/components/microlink/src/ml_derp.c
+++ b/components/microlink/src/ml_derp.c
@@ -626,8 +626,15 @@ void ml_derp_tx_task(void *arg) {
             }
         }
 
-        /* Yield briefly */
-        vTaskDelay(pdMS_TO_TICKS(1));
+        /* Yield between poll cycles. The DERP socket is O_NONBLOCK (see ml_derp_connect),
+         * so SO_RCVTIMEO does NOT actually block reads: poll_derp_read returns immediately
+         * when idle. With CONFIG_FREERTOS_HZ=100, pdMS_TO_TICKS(1) rounds to 0 ticks, so the
+         * old 1ms "yield" was no delay at all -- this task busy-spun at ~8500 loops/s,
+         * starving CPU0's idle task (task_wdt fires) and flooding the lwIP tcpip thread with
+         * a setsockopt() per spin (ml_derp_bio_recv_timeout), which stalled the agent's
+         * backend TCP connect. 10ms = 1 tick guarantees a real yield (~100 polls/s, still
+         * far more responsive than the intended 100ms rhythm). */
+        vTaskDelay(pdMS_TO_TICKS(10));
     }
 
     ESP_LOGI(TAG, "DERP I/O task exiting");
